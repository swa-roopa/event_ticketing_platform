# Production - only these 2 are needed
AWS_REGION=us-east-1
DB_SECRET_NAME=globaltix/database/credentials

# ============== LOCAL DEV ONLY ==============
# Set USE_SECRETS_MANAGER=false to use these instead
USE_SECRETS_MANAGER=false
PRIMARY_DB_HOST=localhost
SECONDARY_DB_HOST=localhost
DB_PORT=3306
DB_NAME=globaltix
DB_USER=globaltix_admin
DB_PASSWORD=localpassword
